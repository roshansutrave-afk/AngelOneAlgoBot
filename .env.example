# AngelOne API credentials
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_CODE=your_client_code
ANGEL_PASSWORD_OR_PIN=your_mpin
ANGEL_TOTP_SECRET=your_totp_secret_from_qr_setup

# ── Trading mode ──────────────────────────────────────────────────────────────
# PAPER = simulated fills, never calls placeOrder
# LIVE  = real orders. Only flip this after sustained PAPER validation.
TRADING_MODE=PAPER

# ── Capital & daily limits ────────────────────────────────────────────────────
# ACCOUNT_CAPITAL: total capital allocated to this bot (₹)
# Keep this to what you're genuinely comfortable losing entirely.
ACCOUNT_CAPITAL=100000
INITIAL_PAPER_CAPITAL=100000

# MAX_DAILY_LOSS: absolute ₹ loss that arms the kill-switch
MAX_DAILY_LOSS=2000
# MAX_DAILY_LOSS_PCT: same limit as % of capital. Whichever trips first wins.
MAX_DAILY_LOSS_PCT=2.0

# MAX_TRADES_PER_DAY: hard cap on new entries regardless of signals
MAX_TRADES_PER_DAY=5

# ── Per-trade risk ─────────────────────────────────────────────────────────────
# RISK_PER_TRADE_PCT: % of ACCOUNT_CAPITAL you're willing to lose on one trade.
# 0.5% of ₹1L = ₹500 max loss per trade. This drives qty sizing via ATR.
RISK_PER_TRADE_PCT=0.5

# ATR_STOP_MULTIPLIER: stop = entry ± (ATR × this). 1.5 = 1.5 ATR stop.
ATR_STOP_MULTIPLIER=1.5
# ATR_TARGET_MULTIPLIER: target = entry ± (ATR × this). Must be > stop mult.
ATR_TARGET_MULTIPLIER=2.5
# MIN_RISK_REWARD: veto any trade where target/stop ratio < this.
MIN_RISK_REWARD=1.5

# MAX_POSITION_QTY: hard share cap regardless of ATR sizing output.
MAX_POSITION_QTY=500

# ALLOW_SHORTS: true = allow shorting (only if you have F&O or margin access)
# false = long-only (recommended for NSE cash equity)
ALLOW_SHORTS=false

# MAX_CONSECUTIVE_LOSSES: pause new entries after this many back-to-back losses
MAX_CONSECUTIVE_LOSSES=3

# ── Execution costs (AngelOne tariff) ─────────────────────────────────────────
SLIPPAGE_BPS=5.0
COMMISSION_PER_ORDER=20.0

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
